{
  "manifest_version": 3,
  "name": "YouTube Ad Auto-Refresher",
  "version": "1.0",
  "description": "Automatically refreshes YouTube when an ad is detected.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}